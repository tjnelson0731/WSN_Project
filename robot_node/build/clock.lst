 251 0000 78B1     		cbz	r0, .L10
 151:Src/clock.c   **** 
 152:Src/clock.c   ****     /*
 153:Src/clock.c   ****      * ARR — Auto-reload register (16-bit).
 154:Src/clock.c   ****      *   The timer counts up to ARR, then fires UIF.
 155:Src/clock.c   ****      *   Period = (ARR + 1) timer ticks.
 156:Src/clock.c   ****      *   With ARR = us - 1: period = us ticks = us µs at 1 MHz.
 157:Src/clock.c   ****      *
 158:Src/clock.c   ****      * Because ARPE = 0 (default, no buffering), writing ARR takes effect
 159:Src/clock.c   ****      * immediately — no EGR_UG needed for the ARR update itself.
 160:Src/clock.c   ****      */
 161:Src/clock.c   ****     TIM6->ARR = (uint16_t)(us - 1U);

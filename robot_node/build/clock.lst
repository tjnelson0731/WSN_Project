   1:Src/clock.c   **** /**
   2:Src/clock.c   ****  * clock.c — System clock configuration + TIM6-based delays
   3:Src/clock.c   ****  *
   4:Src/clock.c   ****  * Target: 80 MHz from HSI16 via PLL on STM32L452RE
   5:Src/clock.c   ****  *
   6:Src/clock.c   ****  * PLL transfer function:
   7:Src/clock.c   ****  *   f_VCO_in  = f_HSI16 / PLLM  =  16 MHz / 1  =  16 MHz
   8:Src/clock.c   ****  *   f_VCO_out = f_VCO_in * PLLN =  16 MHz * 10  = 160 MHz
   9:Src/clock.c   ****  *   f_PLLR    = f_VCO_out / PLLR = 160 MHz / 2  =  80 MHz  → SYSCLK
  10:Src/clock.c   ****  *
  11:Src/clock.c   ****  * Constraints (RM0394):
  12:Src/clock.c   ****  *   f_VCO_in  ∈ [4, 16] MHz            → 16 MHz ✓
  13:Src/clock.c   ****  *   f_VCO_out ∈ [64, 344] MHz          → 160 MHz ✓
  14:Src/clock.c   ****  *   f_SYSCLK  ≤ 80 MHz (Range 1)       → 80 MHz ✓
  15:Src/clock.c   ****  *   Flash latency: 4 WS for 64–80 MHz  (Table 9, RM0394)
  16:Src/clock.c   ****  *
  17:Src/clock.c   ****  * Delay timer — TIM6 (basic timer, RM0394 §29):
  18:Src/clock.c   ****  *   TIM6 is a 16-bit up-counter on APB1 with no output channels.
  19:Src/clock.c   ****  *   It is configured here in one-pulse mode (OPM) for blocking delays.
  20:Src/clock.c   ****  *
  21:Src/clock.c   ****  *   Timer clock = PCLK1 / (PSC + 1) = 80 MHz / 80 = 1 MHz  → 1 tick = 1 µs
  22:Src/clock.c   ****  *   OPM: the counter counts from 0 to ARR, sets UIF, then stops (CEN cleared).
  23:Src/clock.c   ****  *   Delay period = (ARR + 1) timer ticks = (ARR + 1) µs.
  24:Src/clock.c   ****  *   Maximum single delay_us call: 65535 µs (16-bit ARR limit).
  25:Src/clock.c   ****  *   For longer delays, use delay_ms, which loops in 1 ms increments.
  26:Src/clock.c   ****  */
  27:Src/clock.c   **** 
  28:Src/clock.c   **** #include "clock.h"
  29:Src/clock.c   **** #include "stm32l452xx.h"
  30:Src/clock.c   **** 
ARM GAS  C:\Users\Taylor\AppData\Local\Temp\cc6WnVE6.s 			page 2


  31:Src/clock.c   **** 
  32:Src/clock.c   **** /* ---------------------------------------------------------------------- */
  33:Src/clock.c   **** void SystemClock_Config(void)
  34:Src/clock.c   **** {
  29              		.loc 1 34 1 view -0
  30              		.cfi_startproc
  31              		@ args = 0, pretend = 0, frame = 0
  32              		@ frame_needed = 0, uses_anonymous_args = 0
  33              		@ link register save eliminated.
  35:Src/clock.c   ****     /* 1. Voltage scaling: Range 1 allows up to 80 MHz.
  36:Src/clock.c   ****      *    Default after reset is already Range 1, but set it explicitly
  37:Src/clock.c   ****      *    in case we were in Range 2 (e.g. waking from low-power mode).   */
  38:Src/clock.c   ****     RCC->APB1ENR1 |= RCC_APB1ENR1_PWREN;

 135:Src/clock.c   **** /**
 136:Src/clock.c   ****  * delay_us — blocking delay of `us` microseconds using TIM6.
 137:Src/clock.c   ****  *
 138:Src/clock.c   ****  * Implementation:
 139:Src/clock.c   ****  *   TIM6 runs at 1 MHz (1 tick = 1 µs), one-pulse mode.
 140:Src/clock.c   ****  *   ARR = us - 1  →  period = (ARR + 1) ticks = us µs.
 141:Src/clock.c   ****  *
 142:Src/clock.c   ****  * The timer counts from 0 to ARR, then sets UIF and stops (CEN cleared).
 143:Src/clock.c   ****  * We poll UIF to detect completion.
 144:Src/clock.c   ****  *
 145:Src/clock.c   ****  * Note: us = 0 returns immediately. Maximum value: 65535 µs.
 146:Src/clock.c   ****  *       Interrupts are not disabled; an ISR firing mid-delay will extend it.
 147:Src/clock.c   ****  */
 148:Src/clock.c   **** void delay_us(uint32_t us)
 149:Src/clock.c   **** {
 244              		.loc 1 149 1 is_stmt 1 view -0
 245              		.cfi_startproc
 246              		@ args = 0, pretend = 0, frame = 0
 247              		@ frame_needed = 0, uses_anonymous_args = 0
 248              		@ link register save eliminated.

 317:Src/icm20948.c ****     /* ---- AK09916 initialization (direct I2C at 0x0C) ------------------ */
 318:Src/icm20948.c **** 
 319:Src/icm20948.c ****     /* Soft-reset the AK09916                                              */
 320:Src/icm20948.c ****     /*
 321:Src/icm20948.c ****      * AK_CNTL3:
 322:Src/icm20948.c ****      *   Bit 0 SRST = 1 → reset all AK09916 registers; self-clears.
 323:Src/icm20948.c ****      *   Datasheet: reset completes within 100 µs.
 324:Src/icm20948.c ****      */
 325:Src/icm20948.c ****     ak_write_reg(AK_CNTL3, AK_CNTL3_SRST);
 326:Src/icm20948.c ****     delay_ms(10U);   /* comfortably longer than the 100 µs reset time      */
 327:Src/icm20948.c **** 
 328:Src/icm20948.c ****     /* Place AK09916 in 20 Hz continuous measurement mode                 */
 329:Src/icm20948.c ****     /*
 330:Src/icm20948.c ****      * AK_CNTL2 MODE[4:0] = 0x04 → Continuous Measurement Mode 2 (20 Hz).
 331:Src/icm20948.c ****      * The AK09916 will continuously update HX/HY/HZ at 20 Hz.
 332:Src/icm20948.c ****      * ST2 must be read after each sample to arm the next measurement;
 333:Src/icm20948.c ****      * ICM20948_ReadMag() includes ST2 in its 9-byte burst, handling
 334:Src/icm20948.c ****      * this automatically.
 335:Src/icm20948.c ****      */
 336:Src/icm20948.c ****     ak_write_reg(AK_CNTL2, AK_MODE_CONT_20HZ);
 337:Src/icm20948.c **** 
 338:Src/icm20948.c ****     /* Wait one full measurement period before the first read              */
 339:Src/icm20948.c ****     delay_ms(50U);   /* 20 Hz period = 50 ms                               */
 340:Src/icm20948.c **** 
 341:Src/icm20948.c ****     return 0;
 342:Src/icm20948.c **** }

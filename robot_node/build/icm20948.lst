 299:Src/icm20948.c ****      *   Bits[5:3] GYRO_DLPFCFG = 011 → ~51.2 Hz 3-dB bandwidth,
 300:Src/icm20948.c ****      *                                   1.125 kHz output data rate
 301:Src/icm20948.c ****      *   Bits[2:1] GYRO_FS_SEL  = 01  → ±500 dps, 65.5 LSB/(°/s)
 302:Src/icm20948.c ****      *   Bit[0]    GYRO_FCHOICE = 1   → route through DLPF
ARM GAS  C:\Users\Taylor\AppData\Local\Temp\ccvpZWbF.s 			page 32


 303:Src/icm20948.c ****      */

 305:Src/icm20948.c **** 
 306:Src/icm20948.c ****     /*
 307:Src/icm20948.c ****      * ACCEL_CONFIG (Bank 2, 0x14):
 308:Src/icm20948.c ****      *   Bits[5:3] ACCEL_DLPFCFG = 011 → ~50.4 Hz 3-dB bandwidth,
 309:Src/icm20948.c ****      *                                    1.125 kHz output data rate

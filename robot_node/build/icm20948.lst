 266:Src/icm20948.c ****     /* Reset all ICM-20948 registers to defaults                           */
 267:Src/icm20948.c ****     /*
 268:Src/icm20948.c ****      * PWR_MGMT_1:
 269:Src/icm20948.c ****      *   Bit 7 DEVICE_RESET = 1 → resets all registers; self-clears.
 270:Src/icm20948.c ****      *   After reset: SLEEP = 1 (device asleep).
 271:Src/icm20948.c ****      */
 272:Src/icm20948.c ****     icm_write_reg(ICM_B0_PWR_MGMT_1, ICM_PWR_MGMT_1_DEVICE_RESET);
 273:Src/icm20948.c ****     delay_ms(100U);   /* datasheet: startup time ≤ 100 ms after reset      */
 274:Src/icm20948.c **** 
 275:Src/icm20948.c ****     /* Wake the device and select the best available clock                 */
 276:Src/icm20948.c ****     /*
 277:Src/icm20948.c ****      * PWR_MGMT_1 = 0x01:
 278:Src/icm20948.c ****      *   Bit 6    SLEEP  = 0   → exit sleep mode
 279:Src/icm20948.c ****      *   Bits[2:0] CLKSEL = 001 → auto-select PLL if ready, else internal.
 280:Src/icm20948.c ****      *   Datasheet recommends CLKSEL = 1 for lowest gyroscope noise.
 281:Src/icm20948.c ****      */
 282:Src/icm20948.c ****     icm_write_reg(ICM_B0_PWR_MGMT_1, ICM_PWR_MGMT_1_CLKSEL_AUTO);
 283:Src/icm20948.c ****     delay_ms(10U);   /* allow PLL to lock */
 284:Src/icm20948.c **** 
 285:Src/icm20948.c ****     /* Enable all accelerometer and gyroscope axes                         */
 286:Src/icm20948.c ****     /*
 287:Src/icm20948.c ****      * PWR_MGMT_2 = 0x00:
 288:Src/icm20948.c ****      *   Bits[5:3] DISABLE_ACCEL = 000 → all three accel axes on
 289:Src/icm20948.c ****      *   Bits[2:0] DISABLE_GYRO  = 000 → all three gyro axes on
 290:Src/icm20948.c ****      */
 291:Src/icm20948.c ****     icm_write_reg(ICM_B0_PWR_MGMT_2, 0x00U);

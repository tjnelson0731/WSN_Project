   1:Src/uart1.c   **** /**
   2:Src/uart1.c   ****  * uart1.c — USART1 interrupt-driven RX, polling TX, 8N1
   3:Src/uart1.c   ****  *
   4:Src/uart1.c   ****  * Pins:
   5:Src/uart1.c   ****  *   PA9   USART1_TX  AF7   → ESP32-C6 RX
   6:Src/uart1.c   ****  *   PA10  USART1_RX  AF7   ← ESP32-C6 TX
   7:Src/uart1.c   ****  *
   8:Src/uart1.c   ****  * RX is interrupt-driven: every received byte is pushed into a 64-byte ring
   9:Src/uart1.c   ****  * buffer inside USART1_IRQHandler.  This prevents the overrun errors (ORE)
  10:Src/uart1.c   ****  * that occur when polling code sleeps for 10 ms while a full 8-byte frame
  11:Src/uart1.c   ****  * arrives in < 1 ms at 115200 baud.
  12:Src/uart1.c   ****  *
  13:Src/uart1.c   ****  * TX remains polling (busy-wait on TXE) — fine because TX is infrequent and
  14:Src/uart1.c   ****  * there is no timing-sensitive work blocked behind it.
  15:Src/uart1.c   ****  *
  16:Src/uart1.c   ****  * Clock source: PCLK2 = 80 MHz (default USART1SEL after SystemClock_Config).
  17:Src/uart1.c   ****  * BRR = 80 000 000 / 115 200 = 694  (error < 0.07 %)
  18:Src/uart1.c   ****  */
  19:Src/uart1.c   **** 
  20:Src/uart1.c   **** #include <stdint.h>
  21:Src/uart1.c   **** #include "stm32l452xx.h"
  22:Src/uart1.c   **** #include "uart1.h"
  23:Src/uart1.c   **** 
  24:Src/uart1.c   **** /* -------------------------------------------------------------------------
  25:Src/uart1.c   ****  * Ring buffer (power-of-two size for cheap masking)
  26:Src/uart1.c   ****  * ------------------------------------------------------------------------- */
  27:Src/uart1.c   **** 
  28:Src/uart1.c   **** #define RX_BUF_SIZE  64u          /* must be a power of two */
  29:Src/uart1.c   **** #define RX_BUF_MASK  (RX_BUF_SIZE - 1u)
ARM GAS  C:\Users\Taylor\AppData\Local\Temp\ccM8G8UD.s 			page 2


  30:Src/uart1.c   **** 
  31:Src/uart1.c   **** static volatile uint8_t  s_rx_buf[RX_BUF_SIZE];
  32:Src/uart1.c   **** static volatile uint32_t s_rx_head = 0u;   /* IRQ writes here  */
  33:Src/uart1.c   **** static volatile uint32_t s_rx_tail = 0u;   /* main code reads here */
  34:Src/uart1.c   **** 

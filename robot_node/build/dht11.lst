 122:Src/dht11.c   ****     /* DHT11 then pulls HIGH (~80 µs).  Wait for rising edge.             */
ARM GAS  C:\Users\Taylor\AppData\Local\Temp\ccH15kMf.s 			page 25


 123:Src/dht11.c   ****     if (!wait_level(1, 100U)) return DHT11_ERROR_TIMEOUT;
 124:Src/dht11.c   **** 
 125:Src/dht11.c   ****     /* Wait for end of that HIGH pulse (falling edge → data begins).      */
 126:Src/dht11.c   ****     if (!wait_level(0, 100U)) return DHT11_ERROR_TIMEOUT;
 127:Src/dht11.c   **** 
 128:Src/dht11.c   ****     /* ------------------------------------------------------------------ */
 129:Src/dht11.c   ****     /* 3. Read 40 data bits                                                */
 130:Src/dht11.c   ****     /* ------------------------------------------------------------------ */
 131:Src/dht11.c   ****     for (int i = 0; i < 40; i++) {
 132:Src/dht11.c   ****         /*
 133:Src/dht11.c   ****          * Each bit starts with ~50 µs LOW.
 134:Src/dht11.c   ****          * Wait for the rising edge that signals the start of the data HIGH.
 135:Src/dht11.c   ****          */
 136:Src/dht11.c   ****         if (!wait_level(1, 100U)) return DHT11_ERROR_TIMEOUT;
 137:Src/dht11.c   **** 
 138:Src/dht11.c   ****         /*
 139:Src/dht11.c   ****          * Sample 40 µs into the HIGH period.
 140:Src/dht11.c   ****          *   "0" bit: HIGH for 26–28 µs → already LOW at t = 40 µs
 141:Src/dht11.c   ****          *   "1" bit: HIGH for 70 µs    → still HIGH at t = 40 µs
 142:Src/dht11.c   ****          */
 143:Src/dht11.c   ****         delay_us(40U);
 144:Src/dht11.c   **** 
 145:Src/dht11.c   ****         bytes[i >> 3] <<= 1;                /* shift byte left          */
 146:Src/dht11.c   ****         if (pin_read()) {
 147:Src/dht11.c   ****             bytes[i >> 3] |= 0x01U;         /* set LSB if pin is HIGH   */
 148:Src/dht11.c   ****         }
 149:Src/dht11.c   **** 
 150:Src/dht11.c   ****         /* Wait for the HIGH to end before the next bit's LOW preamble.  */
 151:Src/dht11.c   ****         if (!wait_level(0, 100U)) return DHT11_ERROR_TIMEOUT;
 152:Src/dht11.c   ****     }
 153:Src/dht11.c   **** 
 154:Src/dht11.c   ****     /* ------------------------------------------------------------------ */
 155:Src/dht11.c   ****     /* 4. Return bus to idle                                               */
 156:Src/dht11.c   ****     /* ------------------------------------------------------------------ */
 157:Src/dht11.c   ****     pin_output();
 158:Src/dht11.c   ****     DHT11_PORT->BSRR = (1UL << DHT11_PIN);
 159:Src/dht11.c   **** 
 160:Src/dht11.c   ****     /* ------------------------------------------------------------------ */
 161:Src/dht11.c   ****     /* 5. Verify checksum                                                  */
 162:Src/dht11.c   ****     /* ------------------------------------------------------------------ */
 163:Src/dht11.c   ****     uint8_t sum = bytes[0] + bytes[1] + bytes[2] + bytes[3];
 164:Src/dht11.c   ****     if (sum != bytes[4]) return DHT11_ERROR_CHECKSUM;
 165:Src/dht11.c   **** 
 166:Src/dht11.c   ****     data->humidity_int = bytes[0];
 167:Src/dht11.c   ****     data->humidity_dec = bytes[1];
 168:Src/dht11.c   ****     data->temp_int     = bytes[2];
 169:Src/dht11.c   ****     data->temp_dec     = bytes[3];
 170:Src/dht11.c   ****     data->checksum     = bytes[4];
 171:Src/dht11.c   **** 
 172:Src/dht11.c   ****     return DHT11_OK;
 173:Src/dht11.c   **** }

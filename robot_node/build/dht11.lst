   1:Src/dht11.c   **** /**
   2:Src/dht11.c   ****  * dht11.c — DHT11 1-wire driver
   3:Src/dht11.c   ****  *
   4:Src/dht11.c   ****  * Protocol summary (DHT11 datasheet §5):
   5:Src/dht11.c   ****  *
   6:Src/dht11.c   ****  *   [HOST → SENSOR]  Start: pull bus LOW ≥ 18 ms, then release (bus floats
   7:Src/dht11.c   ****  *                    HIGH via pull-up), wait 20–40 µs.
   8:Src/dht11.c   ****  *
   9:Src/dht11.c   ****  *   [SENSOR → HOST]  Response: 80 µs LOW, then 80 µs HIGH.
  10:Src/dht11.c   ****  *
  11:Src/dht11.c   ****  *   [SENSOR → HOST]  40 data bits, MSB first:
  12:Src/dht11.c   ****  *     Each bit starts with ~50 µs LOW, then:
  13:Src/dht11.c   ****  *       "0" → 26–28 µs HIGH
  14:Src/dht11.c   ****  *       "1" → 70 µs HIGH
  15:Src/dht11.c   ****  *
  16:Src/dht11.c   ****  *   Bit decoding: sample at t = 40 µs after the rising edge.
  17:Src/dht11.c   ****  *     If still HIGH  → bit = 1  (only "1" bits are still HIGH at 40 µs)
  18:Src/dht11.c   ****  *     If already LOW → bit = 0  (a "0" bit lasts only 26–28 µs)
  19:Src/dht11.c   ****  *
  20:Src/dht11.c   ****  *   Payload (40 bits = 5 bytes):
  21:Src/dht11.c   ****  *     byte[0] = humidity integer
  22:Src/dht11.c   ****  *     byte[1] = humidity decimal  (always 0 for DHT11)
  23:Src/dht11.c   ****  *     byte[2] = temperature integer
  24:Src/dht11.c   ****  *     byte[3] = temperature decimal (always 0 for DHT11)
  25:Src/dht11.c   ****  *     byte[4] = checksum = (byte[0]+byte[1]+byte[2]+byte[3]) & 0xFF
  26:Src/dht11.c   ****  *
  27:Src/dht11.c   ****  * Data pin: PA1
  28:Src/dht11.c   ****  *   Output mode: push-pull, no pull  (we drive the bus)
  29:Src/dht11.c   ****  *   Input mode : floating + internal pull-up (~40 kΩ) as fallback;
  30:Src/dht11.c   ****  *                use external 4.7 kΩ for reliable results.
  31:Src/dht11.c   ****  */
ARM GAS  C:\Users\Taylor\AppData\Local\Temp\ccH15kMf.s 			page 2



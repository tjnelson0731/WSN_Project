  34:Src/main.c    ****  * ========================================================================= */
  35:Src/main.c    **** 
  36:Src/main.c    **** #define TEMP_INTERVAL_MS 4000U    /* how often to send temperature (ms)      */
  37:Src/main.c    **** #define TICK_MS            10U    /* main loop tick period (ms)               */
  38:Src/main.c    **** 
  39:Src/main.c    **** /* =========================================================================
  40:Src/main.c    ****  * UART1 frame protocol
  41:Src/main.c    ****  * ========================================================================= */
  42:Src/main.c    **** 
  43:Src/main.c    **** #define FRAME_START      0xAAu
  44:Src/main.c    **** #define FRAME_TYPE_TEMP  0x01u    /* STM32 → ESP: temperature                */
  45:Src/main.c    **** #define FRAME_TYPE_POS   0x02u    /* ESP → STM32: computed 2D position       */
  46:Src/main.c    **** 
  47:Src/main.c    **** /* =========================================================================
  48:Src/main.c    ****  * Temperature TX
  49:Src/main.c    ****  * ========================================================================= */
  50:Src/main.c    **** 
  51:Src/main.c    **** static void send_temp_frame(int16_t tenths_f)
  52:Src/main.c    **** {
  53:Src/main.c    ****     uint8_t lo = (uint8_t)((uint16_t)tenths_f & 0xFFu);
  54:Src/main.c    ****     uint8_t hi = (uint8_t)((uint16_t)tenths_f >> 8u);
  55:Src/main.c    ****     uint8_t frame[6] = {
  56:Src/main.c    ****         FRAME_START,
  57:Src/main.c    ****         FRAME_TYPE_TEMP,
  58:Src/main.c    ****         2u,
  59:Src/main.c    ****         lo,
  60:Src/main.c    ****         hi,
  61:Src/main.c    ****         (uint8_t)(FRAME_TYPE_TEMP ^ 2u ^ lo ^ hi)
  62:Src/main.c    ****     };
  63:Src/main.c    ****     UART1_SendBytes(frame, sizeof(frame));
  64:Src/main.c    **** }
  65:Src/main.c    **** 

  85:Src/main.c    **** static void print_tenths(int32_t t)
  86:Src/main.c    **** {
  87:Src/main.c    ****     if (t < 0) { UART_SendChar('-'); t = -t; }
  88:Src/main.c    ****     print_u32((uint32_t)(t / 10));
  89:Src/main.c    ****     UART_SendChar('.');
